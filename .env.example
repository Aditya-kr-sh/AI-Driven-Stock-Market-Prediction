# Environment Configuration
ENV=development
DEBUG=true

# Database Settings
# By default, SQLite will create a stock_market.db in the project root
DATABASE_URL=sqlite:///d:/stockproject/stock_market.db

# Model Storage Directory
MODEL_DIR=d:/stockproject/saved_models

# Stock Data Downloader Defaults
DEFAULT_START_DATE=2018-01-01
DEFAULT_END_DATE=2026-01-01
